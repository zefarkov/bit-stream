<script src="../assets/js/app.js"></script>
<script>const THEME_ICON_SUN='../assets/icons/sun.svg'; const THEME_ICON_MOON='../assets/icons/moon.svg';</script>


<script>
(function(){
 const saved=localStorage.getItem('theme');
 if(saved==='dark'){document.documentElement.setAttribute('data-theme','dark');}
})();
function iconPath(name){return '../assets/icons/'+name+'.svg';}
function updateThemeIcon(){
 const btn=document.getElementById('themeBtn');
 if(!btn)return;
 const dark=document.documentElement.getAttribute('data-theme')==='dark';
 btn.innerHTML='<img src="'+(dark?iconPath('sun'):iconPath('moon'))+'" alt="">';
}
function toggleTheme(){
 const el=document.documentElement;
 const dark=el.getAttribute('data-theme')==='dark';
 if(dark){el.removeAttribute('data-theme');localStorage.setItem('theme','light');}
 else{el.setAttribute('data-theme','dark');localStorage.setItem('theme','dark');}
 updateThemeIcon();
}
document.addEventListener('DOMContentLoaded',function(){
 const lang=document.querySelector('[data-lang-select]');
 if(lang && !document.getElementById('themeBtn')){
   const b=document.createElement('button');
   b.id='themeBtn'; b.className='theme-btn'; b.type='button';
   b.setAttribute('aria-label','Theme');
   b.onclick=toggleTheme;
   lang.parentNode.insertBefore(b,lang);
   updateThemeIcon();
 }
});
</script>
<script>
function updateLogo(){
  const logo = document.getElementById('siteLogo');
  if(!logo) return;

  const dark = document.documentElement.getAttribute('data-theme') === 'dark';

  logo.src = dark
    ? '../assets/img/brand/logo-bitstream-dark.png'
    : '../assets/img/brand/logo-bitstream.png';
}

const oldUpdateThemeIcon = updateThemeIcon;
updateThemeIcon = function(){
  oldUpdateThemeIcon();
  updateLogo();
};

document.addEventListener('DOMContentLoaded', updateLogo);
</script>
<script defer src="/tracker.js"></script>
